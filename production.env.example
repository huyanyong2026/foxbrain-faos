# Production template: copy to the deployment secret store or a local .env.
# Do not commit real passwords, SAP credentials, API keys, or production tokens.
COMPOSE_PROJECT_NAME=vafox-foxbrain
LOG_LEVEL=INFO
JWT_SECRET=change_me_generate_a_long_random_secret
UPSTREAM_TIMEOUT_SECONDS=5
GATEWAY_PORT=8088
AI_WEB_PORT=3000
HUYAN_WEB_PORT=3001
NEXT_PUBLIC_API_BASE_URL=https://pilot.example.com

POSTGRES_DB=vafox_memory
POSTGRES_USER=vafox
POSTGRES_PASSWORD=change_me_postgres_password
DATABASE_URL=postgresql://vafox:change_me_postgres_password@postgres:5432/vafox_memory
REDIS_URL=redis://redis:6379/0
MINIO_ROOT_USER=vafoxadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=vafox-memory
MINIO_ENDPOINT=http://minio:9000
MEMORY_API_PORT=8080
