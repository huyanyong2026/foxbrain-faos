# Store real values only in /etc/firefox-explorer.env on the Gateway host.
EXPLORER_HOST=127.0.0.1
EXPLORER_PORT=8092
EXPLORER_DB=/var/lib/firefox-explorer/explorer.db
EXPLORER_IDENTITY_SECRET=replace-with-at-least-32-random-characters
# Trusted HTTPS webhook. It receives phone, code, scene and expires_minutes as JSON.
# Leave both values blank until the production SMS channel is approved.
EXPLORER_SMS_ENDPOINT=
EXPLORER_SMS_TOKEN=
CORE_BASE_URL=https://core.vafox.com
EXPLORER_CORE_API_TOKEN=
