# Add these locations inside the existing ai.vafox.com HTTPS server.
# Keep the existing /api, /console, /v1, /wecom and /n8n routes unchanged.

location ~ ^/(dashboard|workbench|agents|wecom|knowledge|tasks|feedback)$ {
    proxy_pass http://127.0.0.1:5010;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location ^~ /replenishment {
    proxy_pass http://127.0.0.1:5010;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location = /admin/data-import {
    proxy_pass http://127.0.0.1:5010;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location ^~ /ops-api/ {
    proxy_pass http://127.0.0.1:5010;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

location ^~ /static/ {
    proxy_pass http://127.0.0.1:5010;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
}
