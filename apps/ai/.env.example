# Secrets must be configured on the server and must never be committed.
AUTH_SECRET_KEY=
FOXBRAIN_ENV=production
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vafox_platform
DB_USER=vafox_admin
DB_PASS=
INTERNAL_SERVICE_TOKEN=

# Enterprise context connections. All source access is read-only.
CORE_BASE_URL=https://core.vafox.com
CORE_API_TOKEN=
REPLENISHMENT_TRIGGER_DAYS=15
REPLENISHMENT_TARGET_DAYS=30
REPLENISHMENT_URGENT_DAYS=7
REPLENISHMENT_TIMEZONE=Asia/Shanghai
REPLENISHMENT_RUN_TIME=22:30
AI_INTERNAL_REPLENISHMENT_URL=http://enterprise-ai:5010/ops-api/internal/replenishment/run
CEO_BRAIN_BASE_URL=https://huyan.vafox.com
CEO_BRAIN_API_TOKEN=

# Enterprise WeCom SSO. Leave empty until the enterprise application is approved.
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=

HOST=0.0.0.0
PORT=5010
