# Test-only, non-secret defaults. Copy to .env only for local test containers.
COMPOSE_PROJECT_NAME=vafox-foxbrain-test
LOG_LEVEL=DEBUG
JWT_SECRET=test_only_not_for_production
UPSTREAM_TIMEOUT_SECONDS=2
GATEWAY_PORT=8088
AI_WEB_PORT=3000
HUYAN_WEB_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088

POSTGRES_DB=vafox_test
POSTGRES_USER=vafox_test
POSTGRES_PASSWORD=test_only_postgres_password
DATABASE_URL=postgresql://vafox_test:test_only_postgres_password@postgres:5432/vafox_test
REDIS_URL=redis://redis:6379/0
MINIO_ROOT_USER=vafoxtest
MINIO_ROOT_PASSWORD=test_only_minio_password
MINIO_BUCKET=vafox-test
MINIO_ENDPOINT=http://minio:9000
MEMORY_API_PORT=8080
