# Copy to .env before starting. Replace every change_me value outside local development.
COMPOSE_PROJECT_NAME=vafox-memory-factory
LOG_LEVEL=INFO

# Required by the Pilot gateway. Generate a long random value for each
# environment; never commit a deployed value.
JWT_SECRET=change_me_generate_a_long_random_secret
UPSTREAM_TIMEOUT_SECONDS=5
# WeCom callback and application credentials. Set these only in the deployed
# environment; never commit actual values.
WECHAT_CORP_ID=
WECHAT_AGENT_ID=
WECHAT_SECRET=
WECHAT_TOKEN=
WECHAT_ENCODING_AES_KEY=
GATEWAY_PORT=8088
AI_WEB_PORT=3000
HUYAN_WEB_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088

POSTGRES_DB=vafox_memory
POSTGRES_USER=vafox
POSTGRES_PASSWORD=change_me_postgres_password
DATABASE_URL=postgresql://vafox:change_me_postgres_password@postgres:5432/vafox_memory
REDIS_URL=redis://redis:6379/0
MINIO_ROOT_USER=vafoxadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=vafox-memory
MINIO_ENDPOINT=http://minio:9000
MEMORY_API_PORT=8080
