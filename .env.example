APP_NAME=VAFOX
APP_ENV=production
APP_URL=https://huyan.vafox.com
APP_PUBLIC_URL=https://huyan.vafox.com

# Huyan reads operating facts only through Enterprise Data Core.
CORE_BASE_URL=https://core.vafox.com
CORE_API_TOKEN=
CORE_API_TIMEOUT=8
CORE_API_CACHE_SECONDS=60

DOMAIN=huyan.vafox.com
TIMEZONE=Asia/Shanghai

APP_DIR=/data/firefox-portal
HOST=0.0.0.0
PORT=3000
MAX_UPLOAD_BYTES=20971520

PORTAL_ADMIN_EMAIL=vafox@126.com
PORTAL_INITIAL_ADMIN_PASSWORD=change_me_admin_password
ADMIN_EMAIL=vafox@126.com
ADMIN_PASSWORD=change_me_admin_password

POSTGRES_DB=foxbrain
POSTGRES_USER=foxbrain
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql://foxbrain:change_me_strong_password@postgres:5432/foxbrain

REDIS_URL=redis://redis:6379

MINIO_ROOT_USER=foxbrain
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=foxbrain

QDRANT_URL=http://qdrant:6333

OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
AI_API_KEY=
AI_PROVIDER=deepseek
AI_DEFAULT_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_MODEL_NAME=deepseek-chat
AI_REQUEST_TIMEOUT=45
AI_MAX_TOKENS=900
EMBEDDING_MODEL=

# Huyan never connects to SAP or runs SAP synchronization.
# The only operating-data source is CORE_BASE_URL above.

WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=manual
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=
TAVILY_API_KEY=
AUTO_APPROVE_WEB_RESEARCH=false

DAILY_REPORT_TIME=08:00
KNOWLEDGE_INDEX_TIME=02:00
BACKUP_TIME=02:30
BACKUP_ENABLED=true
BACKUP_SCRIPT=/app/backup.sh
WEB_RESEARCH_TIME=10:00
WEEKLY_REPORT_TIME=MON 09:00
MONTHLY_REPORT_DAY=1
MONTHLY_REPORT_TIME=09:00

ENABLE_N8N=false
ENABLE_DIFY=false
ENABLE_WIKIJS=false
ENABLE_OLLAMA=false

PG_HOST=postgres
PG_PORT=5432
PG_DB=foxbrain
PG_USER=foxbrain
PG_PASSWORD=change_me_strong_password

JWT_SECRET=change_me_jwt_secret
ENCRYPTION_KEY=change_me_encryption_key
MONTH_TARGET=900000
