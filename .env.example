# Copy to .env before starting. Replace every change_me value outside local development.
COMPOSE_PROJECT_NAME=vafox-foundation
LOG_LEVEL=INFO
JWT_SECRET=change_me_use_a_long_random_32_byte_secret
JWT_TTL_SECONDS=3600
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change_me_bootstrap_admin_password
UPSTREAM_TIMEOUT_SECONDS=5

POSTGRES_DB=vafox
POSTGRES_USER=vafox
POSTGRES_PASSWORD=change_me_postgres_password
DATABASE_URL=postgresql://vafox:change_me_postgres_password@postgres:5432/vafox
REDIS_URL=redis://redis:6379/0
MINIO_ROOT_USER=vafoxadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=vafox-foundation
MINIO_ENDPOINT=http://minio:9000
GATEWAY_PORT=8080
